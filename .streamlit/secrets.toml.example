# Used by Streamlit Community Cloud. Configure these via the
# "Secrets" pane in the Streamlit Cloud dashboard rather than committing this file.
ANTHROPIC_API_KEY = "sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx"
ANTHROPIC_MODEL = "claude-sonnet-4-6"
EMBEDDING_MODEL = "pritamdeka/S-PubMedBert-MS-MARCO"
CHROMA_PERSIST_DIR = "./data/chroma"
CHROMA_COLLECTION = "medical_literature"
CHUNK_SIZE = "800"
CHUNK_OVERLAP = "120"
TOP_K = "5"
