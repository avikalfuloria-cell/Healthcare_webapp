# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Model used for the generation step of the RAG pipeline
ANTHROPIC_MODEL=claude-sonnet-4-6

# Where ChromaDB persists its index on disk
CHROMA_PERSIST_DIR=./data/chroma

# Name of the Chroma collection
CHROMA_COLLECTION=medical_literature

# Sentence-transformer model used to embed text.
# PubMedBERT-based, fine-tuned on MS MARCO for retrieval.
EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Retrieval
TOP_K=5
